    <item>
      <title>Autoglm_add_skills</title>
      <link>http://localhost:1313/post/autoglm_add_skills/</link>
      <pubDate>Thu, 26 Feb 2026 23:16:52 +0800</pubDate>
      <guid>http://localhost:1313/post/autoglm_add_skills/</guid>
